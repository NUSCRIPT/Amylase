#Impute missing data
#First replace 'NA' in the BAL culture columns with the text 'NA' since there is nothing to impute in these cells, NA means no growth/normal flora
df2[35:49][is.na(df2[35:49])] <- 'NA'
df2_imp <- mice(df2,m=5,maxit=50,meth="cart",seed=500)
df2_imp <- complete(df2_imp, 1) 

#Visualize missing data to ensure there are no longer any missing datapoints
vis_miss(df2_imp)

#Alternative approach to impute missing data
#Impute missing data by splitting dataframe into columns with continuous variables (a) and the culture results (b)
a <- df2[1:35]
b <- df2 %>% select(patient_ir_id, gram_stain_report_organisms, organism_1_quantity, organism_1_name, organism_2_quantity, organism_2_name, organism_3_quantity, organism_3_name, organism_4_quantity, organism_4_name, organism_5_quantity, organism_5_name, organism_6_quantity, organism_6_name, Quartile, group)

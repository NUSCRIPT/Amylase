Alive3 <- Alive3 %>% mutate(Amylase_300 = case_when(amylase <= 300 ~ "0-300", amylase > 300 ~ "> 300"))
Alive3 <- Alive3 %>% mutate(Amylase_400 = case_when(amylase <= 400 ~ "0-400", amylase > 400 ~ "> 400"))
Alive3 <- Alive3 %>% mutate(Amylase_500 = case_when(amylase <= 500 ~ "0-500", amylase > 500 ~ "> 500"))

